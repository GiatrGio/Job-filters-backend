SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SECRET_KEY=sb_secret_<...>
SUPABASE_JWKS_URL=https://<your-project-ref>.supabase.co/auth/v1/.well-known/jwks.json

LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-<...>
ANTHROPIC_MODEL=claude-haiku-4-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional pricing overrides for admin cost estimates. Leave at 0 to use the
# built-in fallback catalog for the default models.
ANTHROPIC_INPUT_COST_USD_PER_MILLION=0
ANTHROPIC_OUTPUT_COST_USD_PER_MILLION=0
OPENAI_INPUT_COST_USD_PER_MILLION=0
OPENAI_OUTPUT_COST_USD_PER_MILLION=0

ALLOWED_ORIGINS=chrome-extension://<dev_ext_id>,http://localhost:3000
FREE_TIER_MONTHLY_LIMIT=50
FREE_TRACKED_JOBS_LIMIT=5
PRO_TRACKED_JOBS_LIMIT=1000
ADMIN_EMAILS=you@example.com

# DOM-extraction diagnostics (Measure 3) backstop: max diagnostic LLM calls per
# user per rolling 24h. The extension already self-caps to one per browser
# session; this only guards against a buggy/malicious client. 0 disables the cap.
DOM_DIAGNOSTICS_DAILY_CAP_PER_USER=50

# Stripe billing. Create a recurring Price in Stripe Dashboard:
# canvasjob Pro, EUR 4.99/month, tax behavior = inclusive.
STRIPE_SECRET_KEY=sk_test_<...>
STRIPE_WEBHOOK_SECRET=whsec_<...>
STRIPE_PRO_PRICE_ID=price_<...>
STRIPE_AUTOMATIC_TAX_ENABLED=true
WEBSITE_URL=http://localhost:3000
PRO_MONTHLY_EVAL_LIMIT=5000
PRO_MONTHLY_CV_TAILORING_LIMIT=20

LOG_LEVEL=INFO
